router_settings:
  routing_strategy: simple-shuffle
  cooldown_time: 30
  allowed_fails: 2
  num_retries: 2
  timeout: 30
  enable_pre_call_checks: false
  ignore_cooldown_on_fallbacks: true
litellm_settings:
  drop_params: true
  num_retries: 2
  request_timeout: 30
  allowed_fails: 2
  cooldown_time: 30
  fallbacks:
    - free-llm:
        - free-llm-fallback
