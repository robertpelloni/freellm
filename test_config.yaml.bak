# LiteLLM Config - Updated 2026-05-29
# Two groups: free-llm (top 3) + free-llm-fallback (remaining)
# Routing: simple-shuffle (picks smart models, not fast small ones)
# Fallback: free-llm -> free-llm-fallback

# PROBE RESULTS:
#   p2/model-2  0.2s score=90.0 (? ctx)
#   p1/model-1  0.1s score=100.0 (? ctx)
model_list:
  - # Rank 1: model-2 via p2 - ? ctx, 0.2s, 70B, score=90
    model_name: free-llm
    litellm_params:
      model: p2/model-2
      timeout: 30
      api_key: os.environ/P2_API_KEY
  - # Rank 2: model-1 via p1 - ? ctx, 0.1s, 100B, score=100
    model_name: free-llm
    litellm_params:
      model: p1/model-1
      timeout: 30
      api_key: os.environ/P1_API_KEY
  - model_name: free-llm-fallback
    litellm_params:
      model: openai/gpt-4.1-mini
      timeout: 30
      api_key: os.environ/GITHUB_TOKEN
      api_base: https://models.github.ai/inference/v1
  - model_name: free-llm-fallback
    litellm_params:
      model: openai/gpt-4.1
      timeout: 30
      api_key: os.environ/GITHUB_TOKEN
      api_base: https://models.github.ai/inference/v1
  - model_name: free-llm-fallback
    litellm_params:
      model: openai/gpt-4o
      timeout: 30
      api_key: os.environ/GITHUB_TOKEN
      api_base: https://models.github.ai/inference/v1
